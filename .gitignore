# Obsidian local workspace / cache
.obsidian/

# Keep notes and attachments, but do not sync local app/plugin state.
# If you later want to sync selected Obsidian settings, remove the line above
# and use more fine-grained ignore rules instead.

# OS metadata
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Editor / temp files
*.tmp
*.temp
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Common local folders
.trash/
.cache/
node_modules/

# Python cache, just in case
__pycache__/
*.py[cod]
.ipynb_checkpoints/
